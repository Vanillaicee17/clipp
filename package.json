{
  "name": "clipp",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.3",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev:relay": "pnpm --filter @clipp/relay dev",
    "dev:desktop": "pnpm --filter @clipp/desktop dev",
    "dev:mobile": "pnpm --filter @clipp/mobile start"
  },
  "devDependencies": {
    "typescript": "^5.6.2"
  }
}
