{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clipp",
  "version": "0.1.0",
  "identifier": "com.clipp.desktop",
  "build": {
    "beforeBuildCommand": "pnpm --dir .. build",
    "beforeDevCommand": "pnpm --dir .. dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "clipp",
        "width": 980,
        "height": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
