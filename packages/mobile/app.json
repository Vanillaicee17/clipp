{
  "expo": {
    "name": "clipp",
    "slug": "clipp",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow clipp to scan your desktop pairing code.",
          "barcodeScannerEnabled": true
        }
      ]
    ],
    "experiments": {
      "autolinkingModuleResolution": true
    }
  }
}
